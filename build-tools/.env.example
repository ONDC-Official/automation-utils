# LLM provider: anthropic | openai-compat
AI_TYPE=

# API key
# - Anthropic         : your Anthropic key
# - Ollama Cloud      : key from https://ollama.com/settings/keys
# - Together / Groq   : your key from those dashboards
# - Local Ollama      : can be omitted (will default to "ollama")
AI_API_KEY=

# Model name
# Anthropic example   : claude-haiku-4-5-20251001
# Ollama Cloud example: qwen3-coder:480b-cloud
# Together example    : meta-llama/Llama-3-70b-chat-hf
# Groq example        : llama3-70b-8192
AI_MODEL=

# (openai-compat only) Base URL of the OpenAI-compatible endpoint
# Ollama Cloud  : https://api.ollama.com/v1
# Local Ollama  : http://localhost:11434/v1
# Together AI   : https://api.together.xyz/v1
# Groq          : https://api.groq.com/openai/v1
AI_BASE_URL=

# ── polish command ───────────────────────────────────────────────────────────
# Cap the number of attribute gaps processed in a single `polish` run.
# Useful for test/dev runs against large configs — limits LLM cost.
# Unset or 0 = no cap.
POLISH_ATTR_LIMIT=

# Cap the number of stub flow-steps processed in a single `polish` run.
# Same semantics as POLISH_ATTR_LIMIT but for the flows phase.
POLISH_FLOW_LIMIT=

# Confidence threshold for auto-approving drafts in the review UI.
# Entries with score ≥ threshold arrive with `approved` pre-checked.
# Range 0..1. Default 0.8.
POLISH_CONFIDENCE=

# Preferred port for the local review web UI. If in use, falls back to a
# random port (OS-assigned). Default 4747.
POLISH_PORT=

# Max in-flight LLM calls during the attributes-draft and flows-draft phases.
# Default 8. Lower if you hit provider rate limits; raise if the provider
# tolerates more parallelism. Capped at 64.
POLISH_CONCURRENCY=