{
    "name": "@ondc/build-tools",
    "version": "0.0.17",
    "description": "ONDC build toolchain — CLI for pipeline ops + library for MongoDB ingestion",
    "type": "module",
    "main": "./dist/lib.js",
    "types": "./dist/lib.d.ts",
    "exports": {
        ".": {
            "types": "./dist/lib.d.ts",
            "default": "./dist/lib.js"
        },
        "./store": {
            "types": "./dist/store/index.d.ts",
            "default": "./dist/store/index.js"
        }
    },
    "bin": {
        "ondc-tools": "./dist/index.js"
    },
    "files": [
        "dist",
        "scripts"
    ],
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
        "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "prepublishOnly": "npm run test && npm run build",
        "prepare": "npm run build",
        "release:patch": "npm version patch && npm publish",
        "release:minor": "npm version minor && npm publish",
        "release:major": "npm version major && npm publish"
    },
    "keywords": [
        "ondc",
        "build",
        "cli",
        "mongodb",
        "ingestion"
    ],
    "author": "",
    "license": "ISC",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@ondc/automation-mock-runner": "^1.3.36",
        "commander": "^14.0.3",
        "json-pointer": "^0.6.2",
        "ondc-code-generator": "^1.0.1",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    },
    "peerDependencies": {
        "mongodb": "^6.0.0"
    },
    "peerDependenciesMeta": {
        "mongodb": {
            "optional": true
        }
    },
    "devDependencies": {
        "@jest/globals": "^30.3.0",
        "@swc/core": "^1.15.21",
        "@swc/jest": "^0.2.39",
        "@types/json-pointer": "^1.0.34",
        "@types/node": "^22.19.15",
        "jest": "^30.3.0",
        "mongodb": "^6.21.0",
        "prettier": "^3.8.1",
        "tsx": "^4.19.0",
        "typescript": "6.0.2"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
